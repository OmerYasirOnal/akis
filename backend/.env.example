# AKIS backend — AI provider configuration (names only; never commit real values)

# Provider selection (optional). If unset, AKIS auto-detects from a present key,
# and falls back to the deterministic mock when no key is configured.
AI_PROVIDER=            # anthropic | openai | openrouter | google | mock
AI_MODEL=               # optional single model for the loop; else per-provider catalog default

# Provider API keys — set the one(s) you use.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=         # or GOOGLE_API_KEY (alias)
GOOGLE_API_KEY=

# Encrypted key store (only needed for the Settings/KeyStore path, not env-only keys).
AI_KEY_ENCRYPTION_KEY=          # 32-byte master key (64 hex chars OR base64 of 32 bytes)
AI_KEY_ENCRYPTION_KEY_VERSION=v1
# Leave AI_KEY_STORE_PATH unset to use the safe default OUTSIDE the repo
# (~/.config/akis/keys.json). Only set it to an absolute path outside any git repo.
# AI_KEY_STORE_PATH=

# Optional base URL overrides (otherwise per-provider defaults from the catalog).
ANTHROPIC_BASE_URL=
OPENAI_BASE_URL=
OPENROUTER_BASE_URL=
GOOGLE_BASE_URL=

# Server
PORT=3000
# Browser-facing origin (REQUIRED for OAuth so redirect_uri matches the registered app;
# in dev set to the frontend, e.g. http://localhost:5173). Prod fails closed without it
# when OAuth is configured.
PUBLIC_BASE_URL=

# ── Auth (JWT-in-cookie) ──────────────────────────────────────────────
AUTH_JWT_SECRET=               # REQUIRED in production (HS256 signing secret); dev uses an ephemeral key
AUTH_COOKIE_NAME=akis_session  # session cookie name
AUTH_COOKIE_MAXAGE=604800      # SECONDS (604800 = 7 days)
AUTH_COOKIE_SECURE=false       # true in production (HTTPS)
AUTH_COOKIE_SAMESITE=lax       # lax | strict | none (none forces Secure)

# ── OAuth (optional; buttons appear only when a provider's id+secret are set) ──
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ── Durable user store (optional; in-memory when unset). Requires `pnpm -C backend add pg`. ──
DATABASE_URL=                  # e.g. postgres://user:pass@host:5432/akis
