# AKIS backend — ENV TEMPLATE (variable NAMES only; NEVER commit real values).
#
# Usage:
#   cp backend/.env.example backend/.env   # then fill the ones you need
#   export AKIS_ENV_FILE=backend/.env       # point the loader at your file
#   pnpm --filter @akis/backend dev
# Notes:
#   • A real shell env var ALWAYS wins over the file (the loader never overrides it).
#   • With NO provider key set, AKIS runs on the deterministic MOCK provider
#     (a fully working keyless demo — no real API calls).
#   • "REQUIRED" below means required only for that capability (real builds / prod / OAuth / DB).

# ═══════════════════════════════════════════════════════════════════════════════
# 1) AI PROVIDER  — set ONE key to run REAL builds (otherwise mock). [most important]
# ═══════════════════════════════════════════════════════════════════════════════
# Optional: force a provider/model. If unset, AKIS auto-detects from whichever key is present.
AI_PROVIDER=                 # anthropic | openai | openrouter | google | mock
AI_MODEL=                    # optional single model id; else the provider catalog default

# Set the key for the provider you use (the per-provider var is preferred):
ANTHROPIC_API_KEY=           # ← recommended (AKIS is Claude-first by default)
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=              # Google Gemini  (GOOGLE_API_KEY is an accepted alias)
GOOGLE_API_KEY=
AI_API_KEY=                  # generic fallback — ONLY used when AI_PROVIDER is set explicitly above

# Optional base-URL overrides (else per-provider catalog defaults):
ANTHROPIC_BASE_URL=
OPENAI_BASE_URL=
OPENROUTER_BASE_URL=
GOOGLE_BASE_URL=

# Encrypted KeyStore — only for the Settings-UI "save key" path (not for env-only keys):
AI_KEY_ENCRYPTION_KEY=             # 32-byte master key: 64 hex chars OR base64 of 32 bytes
AI_KEY_ENCRYPTION_KEY_VERSION=v1
# AI_KEY_STORE_PATH=               # default ~/.config/akis/keys.json — keep it OUTSIDE any git repo

# ═══════════════════════════════════════════════════════════════════════════════
# 2) SERVER
# ═══════════════════════════════════════════════════════════════════════════════
PORT=3000
NODE_ENV=development         # development | production  (prod fails closed without AUTH_JWT_SECRET)
PUBLIC_BASE_URL=             # browser-facing origin. REQUIRED for OAuth + cross-site cookies.
                             # dev → the frontend, e.g. http://localhost:5173

# ═══════════════════════════════════════════════════════════════════════════════
# 3) AUTH  (JWT-in-cookie)
# ═══════════════════════════════════════════════════════════════════════════════
AUTH_JWT_SECRET=             # REQUIRED in production (HS256 signing secret); dev uses an ephemeral key
AUTH_COOKIE_NAME=akis_session
AUTH_COOKIE_MAXAGE=604800    # seconds (604800 = 7 days)
AUTH_COOKIE_SECURE=false     # true in production (HTTPS)
AUTH_COOKIE_SAMESITE=lax     # lax | strict | none   (none forces Secure)
AUTH_COOKIE_DOMAIN=          # optional, e.g. .yourdomain.com to share the cookie across subdomains

# ═══════════════════════════════════════════════════════════════════════════════
# 4) OAuth  (optional — a button appears only when a provider's id AND secret are both set)
# ═══════════════════════════════════════════════════════════════════════════════
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ═══════════════════════════════════════════════════════════════════════════════
# 5) Durable user store  (optional — in-memory when unset). Needs: pnpm -C backend add pg
# ═══════════════════════════════════════════════════════════════════════════════
DATABASE_URL=                # e.g. postgres://user:pass@host:5432/akis

# ═══════════════════════════════════════════════════════════════════════════════
# 6) Feature flags / runtime  (all optional; safe defaults shown — leave blank to disable)
# ═══════════════════════════════════════════════════════════════════════════════
AKIS_RAG=                    # 1/true → embedded RAG (knowledge retrieval + retrieve_knowledge tool). default OFF
AKIS_REAL_TESTS=             # 1/true → REAL Playwright+Cucumber verification (needs browsers). default mock
AKIS_ALLOW_MOCK=             # 1/true → force the deterministic mock provider + demo verify (keyless demo)
AKIS_DEMO_VERIFY=            # 1/true → mock test runner passes so a run reaches done WITHOUT real browsers
AKIS_WORKSPACES_DIR=         # where generated apps run/preview; default ~/.akis/workspaces
# AKIS_ENV_FILE is the POINTER to this file — set it in your SHELL, not inside the file:
#   export AKIS_ENV_FILE=backend/.env
