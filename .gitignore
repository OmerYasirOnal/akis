# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
build/
*.tsbuildinfo

# Emitted TS artifacts that must NEVER live next to sources (they shadow .ts under
# vitest's bundler resolution and cause stale-code test runs). The project is
# typecheck-only (tsc --noEmit); any of these under src/test/scripts is garbage.
backend/src/**/*.js
backend/src/**/*.js.map
backend/src/**/*.d.ts
# Hand-authored ambient type shims are SOURCE, not emitted artifacts — keep them.
!backend/src/types/*.d.ts
backend/test/**/*.js
backend/test/**/*.js.map
backend/test/**/*.d.ts
backend/scripts/**/*.js
backend/scripts/**/*.js.map
backend/scripts/**/*.d.ts
shared/src/**/*.js
shared/src/**/*.js.map
shared/src/**/*.d.ts
frontend/src/**/*.js
frontend/src/**/*.js.map

# Env & secrets
.env
.env.*
!.env.example
*.local

# Logs
*.log
logs/

# Claude Code runtime state (ephemeral; live sessionId + pid — never commit)
.claude/*.lock
.claude/scheduled_tasks.lock

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json

# Test / coverage
coverage/
.nyc_output/

# Playwright E2E run artifacts (report + per-test traces/screenshots)
playwright-report/
test-results/
blob-report/
.playwright/

# Misc
tmp/
.cache/

# spawned-session live status (ephemeral)
.akis/sessions/*.status.md
.akis/sessions/registry.tsv

# encrypted key store (never commit) — non-anchored globs cover ANY subdir (e.g. backend/.akis/)
**/.akis/keys.json
**/.akis/*.json
.akis/keys.json
# persisted dev auth secret (never commit — PR #95 review)
**/.akis/dev-secret
.akis/*.json

# Playwright MCP run artifacts (screenshots, snapshots, console logs)
.playwright-mcp/
akis-*.jpeg
